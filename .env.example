# Copy to .env locally. Do not commit real secrets.
APP_ENV=development
DATABASE_URL=postgresql://gcagent:change-me@localhost:5432/gcagent
GCAGENT_API_TOKENS=replace-with-long-random-token
GCAGENT_MAX_UPLOAD_BYTES=26214400
GCAGENT_ALLOWED_AUDIO_TYPES=audio/mpeg,audio/mp4,audio/wav,audio/x-wav,audio/webm,audio/ogg
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/gcagent
N8N_TIMEOUT_SECONDS=10
SLACK_SIGNING_SECRET=replace-with-slack-signing-secret
